# CloudBack 后端环境变量
# 复制本文件为 .env 并按你的环境修改（.env 已被 .gitignore 忽略）
#
# Spring Boot 启动时自动从工作目录向上查找并加载 .env
# 在项目根目录（CloudBack/）执行 mvn 命令即可
#
# 支持 ${KEY} 引用其他变量，修改 VM_HOST 即可一键切换

# VM 宿主机 IP（改这一个，下面所有地址跟着变）
VM_HOST=localhost

# MySQL（宿主机已安装）
MYSQL_ADDR=${VM_HOST}:3306
MYSQL_USER=root
MYSQL_PASSWORD=root

# Redis（宿主机已安装）
REDIS_ADDR=${VM_HOST}
REDIS_PORT=6379
REDIS_PASSWORD=redis

# Nacos（Docker）
NACOS_ADDR=${VM_HOST}:8848

# Sentinel（Docker）
SENTINEL_ADDR=${VM_HOST}:8858

# Kafka（Docker）
KAFKA_ADDR=${VM_HOST}:9092

# MinIO 对象存储（Docker）
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=

# 支付宝沙箱
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=

# JWT 密钥（至少 256 位）
JWT_SECRET=

# Meilisearch 搜索引擎（Docker）
MEILI_HOST=
MEILI_PORT=
MEILI_MASTER_KEY=

CLOUD_INTERNAL_TOKEN=
