# CloudBack Docker Compose 环境变量
# 复制本文件为 .env 并按你的环境修改
# 仅用于 docker compose 启动 Nacos / Kafka / Sentinel / MinIO / Meilisearch 容器

# MySQL 宿主机配置（供 Nacos 容器连接）
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_PORT=

# Kafka 广播地址（改为你的 VM 的 IP）
KAFKA_HOST=

# MinIO 对象存储
MINIO_USER=
MINIO_PASSWORD=

# Meilisearch 搜索引擎
MEILI_MASTER_KEY=
